{
  "name": "taskforge-enterprise",
  "version": "0.1.0",
  "private": true,
  "description": "Team Task Manager SaaS — monorepo (web + api)",
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "dev": "run-p dev:web dev:api",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w api",
    "build": "npm run build -w web && npm run build -w api",
    "lint": "npm run lint -w web && npm run lint -w api",
    "db:generate": "npm run db:generate -w api",
    "db:migrate": "npm run db:migrate -w api",
    "db:seed": "npm run db:seed -w api"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.7.0",
    "npm-run-all": "^4.1.5"
  }
}
